{
  "name": "dimensions-website",
  "private": true,
  "description": "Dimensions website",
  "type": "module",
  "scripts": {
    "prebuild": "bun scripts/generate-manifest.ts",
    "build": "qwik build",
    "build.client": "vp build",
    "build.preview": "vp build --ssr src/entry.preview.tsx",
    "build.server": "qwik check-client src dist && vp build -c adapters/cloudflare-pages/vite.config.ts",
    "build.types": "tsc --incremental --noEmit",
    "deploy": "wrangler pages deploy ./dist",
    "dev": "vp dev --mode ssr",
    "dev.debug": "node --inspect-brk ./node_modules/vite/bin/vite.js --mode ssr --force",
    "drizzle:check": "drizzle-kit check",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:pull": "drizzle-kit pull",
    "drizzle:push": "drizzle-kit push",
    "drizzle:studio": "drizzle-kit studio",
    "drizzle:up": "drizzle-kit up",
    "wrangler:migrate-local": "wrangler d1 migrations apply birdflop",
    "fmt": "vp fmt .",
    "fmt.check": "vp fmt --check .",
    "lint": "vp lint --quiet",
    "postinstall": "drizzle-kit generate && wrangler types",
    "preview": "qwik build preview && vp preview --open",
    "serve": "wrangler pages dev ./dist --compatibility-flags=nodejs_als",
    "start": "vp dev --open --mode ssr",
    "qwik": "qwik",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@auth/qwik": "^0.9.2",
    "@luminescent/icons-qwik": "0.1.1",
    "@luminescent/ui": "^7.0.2",
    "@luminescent/ui-qwik": "7.0.0-20",
    "@qwik.dev/core": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/core@8785",
    "@qwik.dev/router": "https://pkg.pr.new/QwikDev/qwik/@qwik.dev/router@8785",
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "*",
    "@types/js-yaml": "^4.0.9",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "globals": "17.7.0",
    "jimp": "^1.6.1",
    "js-yaml": "^5.1.0",
    "lucide-icons-qwik": "1.24.0-qwik-v2",
    "oxlint-plugin-qwik": "^0.0.9",
    "simple-icons-qwik": "16.19.0-qwik-v2",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "latest",
    "undici": "*",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=23.11.0"
  }
}
