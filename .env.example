# Cloudflare Pages Environment Variables Example
# Duplicate this file to `.env` for local development and fill in the values.
# For production, set these variables in the Cloudflare Pages Dashboard under Settings -> Environment Variables.

# Discord Integration
DISCORD_CLIENT_ID="YOUR_DISCORD_CLIENT_ID"
DISCORD_CLIENT_SECRET="YOUR_DISCORD_CLIENT_SECRET"

# Patreon Integration
PATREON_CLIENT_ID="YOUR_PATREON_CLIENT_ID"
PATREON_CLIENT_SECRET="YOUR_PATREON_CLIENT_SECRET"
PATREON_REDIRECT_URI="http://localhost:5173/linkPatreon" # Update for production

# PayPal Integration
PAYPAL_CLIENT_ID="YOUR_PAYPAL_CLIENT_ID"
PAYPAL_CLIENT_SECRET="YOUR_PAYPAL_CLIENT_SECRET"